# Lokalna baza uruchamiana przez docker-compose
DATABASE_URL="postgresql://staty:staty@localhost:5432/staty_pilkarskie?schema=public"

# Opcjonalny bezpośredni URL używany przez Prisma CLI do migracji.
# Integracja Prisma Postgres w Vercelu może ustawić go jako POSTGRES_URL.
# POSTGRES_URL="postgresql://..."

# Minimum 32 losowe znaki. W produkcji nie używaj wartości przykładowej.
AUTH_SECRET="zmien-na-losowy-ciag-minimum-32-znaki"

# Używane przez seed lokalny i jednorazowy bootstrap produkcji
ADMIN_EMAIL="admin@staty.local"
ADMIN_PASSWORD="Staty-Start-2026!"


# Klucz dostawcy API-Football. Opcjonalny do momentu uruchomienia automatyzacji.
# API_FOOTBALL_KEY=""
