generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum DataSourceType {
  MANUAL
  CSV
  XLSX
  API
}

enum ImportStatus {
  PENDING
  VALIDATING
  READY
  COMPLETED
  FAILED
}

enum ImportRowStatus {
  VALID
  DUPLICATE
  INVALID
  IMPORTED
  SKIPPED
}

enum AuditEntityType {
  MATCH
  MATCH_STATS
  TEAM
  REFEREE
  SEASON
  LEAGUE
  ANALYSIS_PICK
  ANALYSIS_STRATEGY
}

enum LineScope {
  MATCH_TOTAL
  TEAM_FOR
  TEAM_AGAINST
}

enum AnalysisPickSide {
  OVER
  UNDER
}

enum AnalysisPickStatus {
  WATCHING
  PLAYED
  REJECTED
  SETTLED
  VOID
}

enum AnalysisPickResult {
  WIN
  LOSS
  PUSH
  VOID
}

enum AnalysisPickSource {
  SCANNER
  MANUAL
}

enum ExternalEntityType {
  LEAGUE
  TEAM
}

enum CurrentDataSyncTrigger {
  MANUAL
  CRON
}

enum CurrentDataSyncRunStatus {
  PREPARING
  READY
  FAILED
}
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  role         UserRole     @default(ANALYST)
  active       Boolean      @default(true)
  customLines  CustomLine[]
  auditLogs    AuditLog[]
  imports      ImportBatch[]
  overrides    DataOverride[]
  analysisNotes MatchAnalysisNote[]
  analysisPicks AnalysisPick[]
  analysisStrategies AnalysisStrategy[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model League {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  country   String
  code      String   @unique
  active    Boolean  @default(true)
  seasons   Season[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Season {
  id               String          @id @default(cuid())
  leagueId         String
  name             String
  startsAt         DateTime
  endsAt           DateTime
  active           Boolean         @default(false)
  league           League          @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  teams            SeasonTeam[]
  matches          Match[]
  refereeSeasons   RefereeSeason[]
  currentDataSyncRuns CurrentDataSyncRun[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([leagueId, name])
  @@index([leagueId, active])
}

model Team {
  id                String       @id @default(cuid())
  name              String
  shortName         String?
  slug              String       @unique
  country           String
  active            Boolean      @default(true)
  seasonMemberships SeasonTeam[]
  homeMatches       Match[]      @relation("HomeTeam")
  awayMatches       Match[]      @relation("AwayTeam")
  selectedAnalysisPicks AnalysisPick[] @relation("AnalysisPickTeam")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model SeasonTeam {
  id        String   @id @default(cuid())
  seasonId  String
  teamId    String
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@unique([seasonId, teamId])
  @@index([teamId])
}

model Referee {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  active      Boolean         @default(true)
  seasons     RefereeSeason[]
  matches     Match[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model RefereeSeason {
  id        String   @id @default(cuid())
  refereeId String
  seasonId  String
  referee   Referee  @relation(fields: [refereeId], references: [id], onDelete: Cascade)
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([refereeId, seasonId])
  @@index([seasonId])
}

model DataSource {
  id           String         @id @default(cuid())
  name         String
  type         DataSourceType
  providerCode String?        @unique
  active       Boolean        @default(true)
  matches      Match[]
  imports      ImportBatch[]
  fieldObservations MatchFieldObservation[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Match {
  id                  String         @id @default(cuid())
  seasonId            String
  round               Int?
  kickoffAt           DateTime
  homeTeamId          String
  awayTeamId          String
  homeScore           Int?
  awayScore           Int?
  status              MatchStatus    @default(SCHEDULED)
  refereeId           String?
  dataSourceId        String?
  sourceExternalId    String?
  sourceUpdatedAt     DateTime?
  note                String?
  season              Season         @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  homeTeam            Team           @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam            Team           @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  referee             Referee?       @relation(fields: [refereeId], references: [id], onDelete: SetNull)
  dataSource          DataSource?    @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  stats               MatchStats?
  overrides           DataOverride[]
  analysisNotes MatchAnalysisNote[]
  fieldObservations MatchFieldObservation[]
  analysisPicks AnalysisPick[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([seasonId, homeTeamId, awayTeamId, kickoffAt])
  @@index([seasonId, kickoffAt])
  @@index([homeTeamId, kickoffAt])
  @@index([awayTeamId, kickoffAt])
  @@index([refereeId])
  @@unique([dataSourceId, sourceExternalId])
}

model MatchStats {
  id                  String   @id @default(cuid())
  matchId             String   @unique
  homeCorners         Int?
  awayCorners         Int?
  homeYellowCards     Int?
  awayYellowCards     Int?
  homeRedCards        Int?
  awayRedCards        Int?
  homeShotsOnTarget   Int?
  awayShotsOnTarget   Int?
  homeShots            Int?
  awayShots            Int?
  homeFouls            Int?
  awayFouls            Int?
  homeOffsides         Int?
  awayOffsides         Int?
  match                Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model DataOverride {
  id          String   @id @default(cuid())
  matchId     String
  fieldName   String
  reason      String?
  createdById String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@unique([matchId, fieldName])
  @@index([createdById])
}

model ImportBatch {
  id            String       @id @default(cuid())
  fileName      String
  status        ImportStatus @default(PENDING)
  sourceId      String?
  createdById   String
  rowsTotal     Int          @default(0)
  rowsValid     Int          @default(0)
  rowsInvalid   Int          @default(0)
  rowsDuplicate Int          @default(0)
  source        DataSource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  createdBy     User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  rows          ImportRow[]
  currentDataSyncRuns CurrentDataSyncRun[]
  createdAt     DateTime     @default(now())
  completedAt   DateTime?

  @@index([createdAt])
}

model ImportRow {
  id         String          @id @default(cuid())
  importId   String
  rowNumber  Int
  status     ImportRowStatus
  rawData    Json
  errors     Json?
  import     ImportBatch     @relation(fields: [importId], references: [id], onDelete: Cascade)
  fieldObservations MatchFieldObservation[]
  createdAt  DateTime        @default(now())

  @@unique([importId, rowNumber])
}

model AuditLog {
  id          String          @id @default(cuid())
  entityType  AuditEntityType
  entityId    String
  action      String
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  changes     AuditChange[]
  createdAt   DateTime        @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model AuditChange {
  id         String   @id @default(cuid())
  auditLogId String
  fieldName  String
  oldValue   String?
  newValue   String?
  auditLog   AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
}

model CustomLine {
  id        String    @id @default(cuid())
  userId    String
  name      String
  statKey   String
  scope     LineScope
  threshold Float
  active    Boolean   @default(true)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, statKey])
}


model MatchAnalysisNote {
  id        String   @id @default(cuid())
  matchId   String
  userId    String
  content   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId])
  @@index([userId, updatedAt])
}
model AnalysisPick {
  id                      String             @id @default(cuid())
  userId                  String
  matchId                 String
  fingerprint             String
  source                  AnalysisPickSource @default(MANUAL)
  statKey                 String
  statLabel               String
  scope                   LineScope          @default(MATCH_TOTAL)
  threshold               Float
  side                    AnalysisPickSide
  status                  AnalysisPickStatus @default(WATCHING)
  result                  AnalysisPickResult?
  projection              Float?
  edge                    Float?
  evidenceStatus          String?
  backtestSignals         Int?
  backtestHitRate         Float?
  edgeBacktestSignals     Int?
  edgeBacktestHitRate     Float?
  homeSample              Int?
  awaySample              Int?
  selectedTeamId          String?
  rawProjection           Float?
  adjustedProjection      Float?
  bookmaker               String?
  odds                    Float?
  oppositeOdds            Float?
  closingOdds             Float?
  quoteCapturedAt         DateTime?
  modelProbability        Float?
  fairOdds                Float?
  bookmakerMargin         Float?
  marketProbability       Float?
  expectedValue           Float?
  modelSample             Int?
  modelCoverage           Float?
  modelConfidence         String?
  marketStatus            String?
  modelVersion             String?
  stake                   Float?
  actualValue             Float?
  note                    String?
  placedAt                DateTime?
  settledAt               DateTime?
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  match                   Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  selectedTeam            Team?              @relation("AnalysisPickTeam", fields: [selectedTeamId], references: [id], onDelete: SetNull)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@unique([userId, fingerprint])
  @@index([userId, status, createdAt])
  @@index([matchId])
  @@index([status, matchId])
  @@index([selectedTeamId])
}

model AnalysisStrategy {
  id                      String   @id @default(cuid())
  userId                  String
  name                    String
  description             String?
  active                  Boolean  @default(true)
  leagueId                String?
  seasonId                String?
  statKey                 String?
  scope                   String?
  target                  String?
  side                    String?
  source                  String?
  modelVersion            String?
  marketStatus            String?
  evidenceStatus          String?
  bookmaker               String?
  decisionMode            String   @default("ALL")
  minModelProbability     Float?
  maxModelProbability     Float?
  minExpectedValue        Float?
  maxExpectedValue        Float?
  minOdds                 Float?
  maxOdds                 Float?
  minThreshold            Float?
  maxThreshold            Float?
  minEdge                 Float?
  minModelSample          Int?
  minCoverage             Float?
  minBacktestSignals      Int?
  minBacktestHitRate      Float?
  minimumConfidence       String?
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId, active, updatedAt])
  @@index([leagueId])
  @@index([seasonId])
}

model LoginThrottle {
  key             String    @id
  scope           String
  failedAttempts  Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  lastAttemptAt   DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([scope, blockedUntil])
  @@index([lastAttemptAt])
}

model LoginSecurityEvent {
  id           String    @id @default(cuid())
  emailHash    String?
  ipHash       String
  userId       String?
  outcome      String
  reason       String?
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())

  @@index([createdAt])
  @@index([outcome, createdAt])
  @@index([emailHash, createdAt])
  @@index([ipHash, createdAt])
}

model CurrentDataSyncRun {
  id             String                   @id @default(cuid())
  seasonId       String
  batchId        String?
  rangeFrom      DateTime
  rangeTo        DateTime
  trigger        CurrentDataSyncTrigger
  status         CurrentDataSyncRunStatus @default(PREPARING)
  error          String?
  season         Season                   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  batch          ImportBatch?             @relation(fields: [batchId], references: [id], onDelete: SetNull)
  startedAt      DateTime                 @default(now())
  lastSelectedAt DateTime                 @default(now())
  finishedAt     DateTime?
  updatedAt      DateTime                 @updatedAt

  @@index([seasonId, lastSelectedAt])
  @@index([seasonId, rangeFrom, rangeTo])
  @@index([status, updatedAt])
}

model CurrentDataSyncLock {
  id          String   @id
  lockToken   String?
  lockedUntil DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MatchFieldObservation {
  id                String     @id @default(cuid())
  matchId           String
  dataSourceId      String
  importRowId       String?
  fieldName         String
  value             String
  active            Boolean    @default(false)
  conflict          Boolean    @default(false)
  ignoredByOverride Boolean    @default(false)
  sourceExternalId  String?
  sourceUpdatedAt   DateTime?
  observedAt        DateTime   @default(now())
  match             Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  dataSource        DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Restrict)
  importRow         ImportRow? @relation(fields: [importRowId], references: [id], onDelete: SetNull)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@unique([matchId, fieldName, dataSourceId])
  @@index([matchId, conflict, active])
  @@index([dataSourceId, fieldName])
}

model ExternalMapping {
  id           String             @id @default(cuid())
  providerCode String
  entityType   ExternalEntityType
  internalId   String
  externalId   String
  externalName String?
  metadata     Json?
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([providerCode, entityType, internalId])
  @@unique([providerCode, entityType, externalId])
  @@index([providerCode, entityType, active])
}
